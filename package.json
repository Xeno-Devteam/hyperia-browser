{
  "name": "hyperia-browser",
  "version": "1.0.0",
  "description": "A clean, minimal browser with installable web and Electron packaging support",
  "author": "Xeno-Devteam",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"vite\" \"electron .\"",
    "dev": "vite",
    "dist": "electron-builder",
    "electron": "electron .",
    "web": "vite preview --host",
    "build": "vite build",
    "electron-pack-win": "electron-builder --win",
    "electron-pack-linux": "electron-builder --linux",
    "electron-pack-mac": "electron-builder --mac",
    "build:web": "vite build",
    "build-electron": "npm run build && electron-builder",
    "package": "npm run build-electron",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.8"
  },
  "build": {
  "appId": "com.hyperia.browser",
  "productName": "Hyperia Browser",
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "directories": {
    "output": "dist-electron"
  },
  "win": {
    "target": "nsis"
  },
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage"
  }
  },
    "appId": "com.hyperia.browser",
    "productName": "Hyperia Browser",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "asar": true,
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }

